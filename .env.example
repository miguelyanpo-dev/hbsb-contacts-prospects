# Server Configuration
PORT=3001
NODE_ENV=development
PRODUCTION_URL=https://hbsb-contacts-prospects.vercel.app
CORS_ORIGIN=*

# Database Configuration (Supabase multi-tenant)
# La URL final se construye como:
#   ${DATABASE_BASE}${ref}:${DATABASE_PASSWORD}${DATABASE_HOST}
# Ejemplo con ref=abcxyz:
#   postgresql://postgres.abcxyz:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres
#
# El parámetro "ref" se envía en cada request como query param: ?ref=<supabase_project_ref>
DATABASE_BASE=postgresql://postgres.
DATABASE_PASSWORD=your_db_password_here
DATABASE_HOST=@aws-1-eu-west-1.pooler.supabase.com:6543/postgres
